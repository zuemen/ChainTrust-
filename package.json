{
  "name": "chaintrust",
  "version": "0.1.0",
  "private": true,
  "description": "鏈信 ChainTrust — SSI 金融身分錢包 + AI 反詐 PoC",
  "license": "MIT",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "contracts:build": "pnpm --filter @chaintrust/contracts build",
    "contracts:test": "pnpm --filter @chaintrust/contracts test",
    "iv:build": "pnpm --filter @chaintrust/issuer-verifier build",
    "iv:test": "pnpm --filter @chaintrust/issuer-verifier test",
    "iv:e2e": "pnpm --filter @chaintrust/issuer-verifier e2e",
    "iv:dev": "pnpm --filter @chaintrust/issuer-verifier dev",
    "wallet:dev": "pnpm --filter @chaintrust/wallet dev",
    "wallet:build": "pnpm --filter @chaintrust/wallet build",
    "ai:dev": "pnpm --filter @chaintrust/ai-service dev",
    "ai:setup": "pnpm --filter @chaintrust/ai-service setup",
    "ai:train": "pnpm --filter @chaintrust/ai-service train",
    "demo": "powershell -ExecutionPolicy Bypass -File scripts/demo.ps1",
    "smoke": "node scripts/smoke.mjs",
    "test": "pnpm --filter @chaintrust/contracts --filter @chaintrust/issuer-verifier test",
    "test:ai": "pnpm --filter @chaintrust/ai-service test"
  }
}
