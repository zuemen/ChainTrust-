# 複製為 .env（已被 .gitignore，勿入庫）
PORT=3001

# 鏈模式：memory（離線 e2e/dev，預設）| ethers（接已部署合約）
CHAIN_MODE=memory

# 接真合約時用
AMOY_RPC_URL=https://rpc-amoy.polygon.technology
# issuer 撤銷/設信任需簽署私鑰（測試錢包，僅 testnet，勿入庫）；缺則唯讀
CHAIN_PRIVATE_KEY=
ETHR_NETWORK=polygon:amoy
ETHR_CHAIN_ID=80002

# AI 反詐服務（M2）
AI_SERVICE_URL=http://localhost:8000

# 階段 C：安全
# mutating 端點（/issue/*、/sdjwt/issue、/revoke）的 API 金鑰；設了才強制檢查 X-API-Key（dev 留空放行）
API_KEY=
# CORS 允許來源（預設僅錢包前端）
CORS_ORIGIN=http://localhost:5173
# 本驗證方 aud 識別（key binding 用）
VERIFIER_AUD=chaintrust-verifier
